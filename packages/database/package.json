{
  "name": "@printos/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "prisma validate --schema prisma/schema.prisma",
    "test": "echo \"No database tests yet\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "node ../../infra/scripts/run-database.mjs generate",
    "db:migrate": "node ../../infra/scripts/run-database.mjs migrate",
    "db:seed": "node ../../infra/scripts/run-database.mjs seed"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0"
  },
  "devDependencies": {
    "prisma": "^6.5.0",
    "tsx": "^4.19.3"
  }
}
