{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": false,
    "outDir": "dist"
  },
  "include": [
    "src/**/*.ts"
  ]
}

